{
  "name": "pay-as-you-go-ai-hacker-server",
  "version": "1.0.0",
  "description": "Backend API for Pay-as-you-go AI Hacker SaaS platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "seed": "ts-node src/utils/seed.ts",
    "prisma:generate": "prisma generate",
    "studio": "prisma studio",
    "test:flow": "ts-node src/utils/test-flow.ts"
  },
  "keywords": [
    "security",
    "ai",
    "saas",
    "stellar",
    "x402"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "prisma": "^6.4.0",
    "@stellar/stellar-sdk": "^15.0.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}